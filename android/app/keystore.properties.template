# Copy this file to keystore.properties (same directory) and fill in your values.
# keystore.properties is gitignored — never commit it.
#
# How to generate a keystore:
#   keytool -genkey -v -keystore sizesync.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias sizesync
#
# Then place sizesync.jks somewhere safe (e.g. android/app/) and set the path below.

storeFile=sizesync.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=sizesync
keyPassword=YOUR_KEY_PASSWORD
